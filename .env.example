# BookBuddARR local stack configuration.
# Copy to .env and fill real values. Do not commit real values.

# BookBuddARR service ports and storage.
BOOKBUDDARR_WEB_PORT=8788
BOOKBUDDARR_TORZNAB_PORT=8765
BOOKBUDDARR_TORZNAB_API_KEY=
BOOKBUDDARR_DEFAULT_QUERY=audiobook
BOOKBUDDARR_DOWNLOAD_MODE=approved_only
BOOKBUDDARR_IMPORT_MODE=copy
BOOKBUDDARR_CANDIDATE_SCORE_THRESHOLD=85

# Required for aggregate search and grab.
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

# Required for torrent handoff and monitoring.
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=
QBITTORRENT_CATEGORY=audiobooks

# Required for import verification by filesystem path; API is optional.
AUDIOBOOKSHELF_URL=http://audiobookshelf:80
AUDIOBOOKSHELF_API_KEY=
AUDIOBOOKSHELF_LIBRARY_PATH=/audiobooks
AUDIOBOOK_ROOT_FR=/Data/Audiobooks/Francais
AUDIOBOOK_ROOT_EN=/Data/Audiobooks/English
AUDIOBOOK_ROOT_UNKNOWN=/Data/Audiobooks

# Optional ebook/library context.
READARR_URL=http://readarr:8787
READARR_API_KEY=

# Optional Usenet clients. SABnzbd has connection testing; NZBGet is documented TODO.
SABNZBD_URL=
SABNZBD_API_KEY=
NZBGET_URL=
NZBGET_USERNAME=
NZBGET_PASSWORD=

# Optional local Torznab bridge fallback.
TORZNAB_URL=http://127.0.0.1:8765/api
TORZNAB_API_KEY=
AUDIOBOOK_SEARCH_BASE_URL=https://audiobookbay.lu
