# Copy to /srv/media-stack/compose/bookbuddarr-torznab.env on Service.
# chmod 600 the real env file.
# Do not commit real values.

BOOKBUDDARR_TORZNAB_API_KEY=change-me
BOOKBUDDARR_SRC=/srv/media-stack/compose/bookbuddarr-src
BOOKBUDDARR_ENV=/srv/media-stack/compose/bookbuddarr-torznab.env
BOOKBUDDARR_DEFAULT_QUERY=audiobook
BOOKBUDDARR_PAGE_LIMIT=2
BOOKBUDDARR_TIMEOUT=15
BOOKBUDDARR_DATA=/srv/media-stack/compose/bookbuddarr-data
BOOKBUDDARR_DOWNLOAD_MODE=approved_only
BOOKBUDDARR_IMPORT_MODE=copy
BOOKBUDDARR_CANDIDATE_SCORE_THRESHOLD=85
AUDIOBOOKBAY_HOSTNAME=audiobookbay.lu

# Required for aggregate search and approved grab workflow.
PROWLARR_URL=http://127.0.0.1:9696
PROWLARR_API_KEY=change-me
PROWLARR_INDEXER_NAME=AudioBookBay Bridge
BOOKBUDDARR_TORZNAB_URL=http://bookbuddarr-torznab:8765/api

# Required for torrent handoff and monitoring.
QBITTORRENT_URL=http://127.0.0.1:8080
QBITTORRENT_USERNAME=change-me
QBITTORRENT_PASSWORD=change-me
QBITTORRENT_CATEGORY=audiobooks

# Required for filesystem import verification; API is optional.
AUDIOBOOKSHELF_URL=http://127.0.0.1:13378
AUDIOBOOKSHELF_API_KEY=
AUDIOBOOKSHELF_LIBRARY_PATH=/audiobooks
AUDIOBOOK_ROOT_FR=/Data/Audiobooks/Francais
AUDIOBOOK_ROOT_EN=/Data/Audiobooks/English
AUDIOBOOK_ROOT_UNKNOWN=/Data/Audiobooks

# Optional Readarr visibility checks.
READARR_URL=http://127.0.0.1:8787
READARR_API_KEY=change-me

# Optional Usenet clients.
SABNZBD_URL=
SABNZBD_API_KEY=
NZBGET_URL=
NZBGET_USERNAME=
NZBGET_PASSWORD=
